# ZENTHRA FRONTEND (Vite) – ejemplo producción
#
# Copia este archivo a `.env` y completa los valores reales antes de construir.

# URL pública del backend (FastAPI detrás de reverse proxy o servicio docker)
VITE_API_URL=http://frontend-proxy.local/api

# Opcional solo para desarrollo local controlado.
# En produccion dejar vacio: /monitoring/* debe usar JWT admin o un proxy servidor.
VITE_ZENTHRA_MONITOR_TOKEN=

# Datos opcionales para visualizaciones (no funcionales si se dejan vacíos)
VITE_ZENTHRA_LAN_CIDR=
VITE_ZENTHRA_VPN_CIDR=
VITE_ZENTHRA_PUBLIC_IP=
VITE_ZENTHRA_LAN_KEY_HOSTS=
VITE_ZENTHRA_EXTERNAL_MONITORED_HOSTS=

# URL pública de Prometheus si se necesita reescritura de links
VITE_PROMETHEUS_PUBLIC_URL=
