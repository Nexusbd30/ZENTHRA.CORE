# =============================================================
# 🔐 Seguridad
# =============================================================
SECRET_KEY=CHANGE_ME_WITH_A_LONG_RANDOM_VALUE
ACCESS_TOKEN_EXPIRE_MINUTES=60
LOG_LEVEL=INFO
ENV=production

# =============================================================
# 🗄️ Base de datos
# =============================================================

# (A) SIMPLE: URI directo
# SQLALCHEMY_DATABASE_URI=sqlite:///./app.db
# SQLALCHEMY_DATABASE_URI=postgresql+psycopg://zenthra:zenthra@127.0.0.1:5432/zenthra

# (B) PRO: construir URI automáticamente con POSTGRES_*
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=zenthra
POSTGRES_USER=zenthra
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# =============================================================
# 🌐 CORS
# =============================================================
CORS_ORIGINS='["http://localhost:5173","http://127.0.0.1:5173","http://localhost:3000","http://127.0.0.1:3000"]'

# =============================================================
# 🛡️ Token interno monitorización
# =============================================================
ZENTHRA_MONITOR_TOKEN=CHANGE_ME_MONITOR_TOKEN

# =============================================================
# 🔔 Observabilidad
# =============================================================
PROMETHEUS_BASE=http://127.0.0.1:9090
ALERTMANAGER_BASE=http://127.0.0.1:9093
PROM_TIMEOUT_SEC=8
PROM_CACHE_TTL_SECONDS=5

# =============================================================
# 🧠 Correlation Scheduler
# =============================================================
ZENTHRA_CORRELATION_ENABLED=true
ZENTHRA_CORRELATION_INTERVAL_SEC=60
ZENTHRA_CORRELATION_STARTUP_DELAY_SEC=5
ZENTHRA_ENABLE_LAB_ALERTS=false
# =============================================================
# AI / LLM (RedQueen)
# =============================================================
AI_ENABLED=true
AI_PROVIDER=local_stub
AI_MODEL=llama3.1:8b
AI_BASE_URL=http://127.0.0.1:11434
AI_TIMEOUT_SEC=8
MCP_CONTEXT_ENABLED=true
MCP_CONTEXT_MODE=manual_context
VECTOR_STORE_ENABLED=true
VECTOR_STORE_PROVIDER=local
VECTOR_DIMENSIONS=64
VECTOR_COLLECTION_PREFIX=zenthra
KAFKA_INGESTION_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_INGESTION_TOPICS=zenthra.siem,zenthra.edr,zenthra.iam,zenthra.netflow
KAFKA_CONSUMER_GROUP_ID=zenthra-core-ingestion
KAFKA_AUTO_OFFSET_RESET=latest
KAFKA_POLL_TIMEOUT_SEC=1
REDQUEEN_AUTONOMY_MAX=95
REDQUEEN_HUMAN_APPROVAL_SCORE=90
ACTION_EXECUTION_MODE=dry_run
ACTION_TIMEOUT_SEC=5
ACTION_SHARED_TOKEN=
NETWORK_CONTROL_URL=
IDENTITY_CONTROL_URL=
ENDPOINT_CONTROL_URL=
SOAR_CONTROL_URL=
CRYPTO_CONTROL_URL=
AI_TEMPERATURE=0.1

# Bootstrap admin local. No hay password por defecto.
BOOTSTRAP_ADMIN_EMAIL=admin@zenthra.dev
BOOTSTRAP_ADMIN_PASSWORD=
